APP_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=24
FERNET_KEY=

DATABASE_URL=postgresql+asyncpg://sparkguard:sparkguard@postgres:5432/sparkguard

FRONTEND_URL=http://localhost:5573

PLAYWRIGHT_HEADLESS=true

LLM_API_KEY=
LLM_BASE_URL=

RATE_LIMIT_ENABLED=true

# 仅 APP_ENV=development 时生效，跳过 JWT 鉴权，使用数据库首个 active 用户
DEV_BYPASS_AUTH=false
